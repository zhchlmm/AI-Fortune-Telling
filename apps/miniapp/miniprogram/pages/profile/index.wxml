<view class="container tab-page">
  <view class="hero card">
    <view class="card-title">个人中心</view>
    <view class="profile-row">
      <image class="avatar" src="{{(editMode ? draftAvatarUrl : avatarUrl) || '/assets/tabbar/profile.png'}}" mode="aspectFill" />
      <view class="profile-main">
        <view class="profile-name">{{nickname}}</view>
        <view class="muted">用户标识：{{userId}}</view>
      </view>
    </view>

    <view class="profile-info" wx:if="{{!editMode}}">
      <view class="info-item">
        <text class="info-label">邮箱</text>
        <text class="info-value">{{email}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">手机号</text>
        <text class="info-value">{{phoneNumber}}</text>
      </view>
      <t-button size="small" variant="outline" bind:tap="toggleEditMode">编辑资料</t-button>
    </view>

    <view class="edit-panel" wx:if="{{editMode}}">
      <t-cell-group border="{{false}}">
        <t-cell title="昵称">
          <t-input
            slot="note"
            value="{{draftNickname}}"
            placeholder="输入昵称（可留空）"
            borderless="true"
            bind:change="onNicknameInput"
          />
        </t-cell>
        <t-cell title="邮箱">
          <t-input
            slot="note"
            value="{{draftEmail}}"
            placeholder="输入邮箱（可留空）"
            borderless="true"
            bind:change="onEmailInput"
          />
        </t-cell>
        <t-cell title="手机号">
          <t-input
            slot="note"
            value="{{draftPhoneNumber}}"
            placeholder="输入手机号（可留空）"
            borderless="true"
            bind:change="onPhoneInput"
          />
        </t-cell>
      </t-cell-group>

      <view class="edit-actions">
        <t-button size="small" variant="outline" bind:tap="useWechatNickname">微信昵称填充</t-button>
        <t-button size="small" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">微信头像</t-button>
      </view>

      <view class="edit-actions">
        <t-button size="small" open-type="getPhoneNumber" bind:getphonenumber="onGetPhoneNumber">微信手机号</t-button>
        <t-button size="small" theme="primary" loading="{{savingProfile}}" bind:tap="saveProfile">保存</t-button>
        <t-button size="small" variant="outline" bind:tap="toggleEditMode">取消</t-button>
      </view>
    </view>

    <view class="member-level" bindtap="goMemberCenter">
      <view class="member-left">
        <t-icon name="{{memberIcon}}" size="36rpx" color="{{memberIconColor}}" />
        <text class="member-name" style="color: {{memberNameColor}};">{{memberLevel}}</text>
      </view>
      <view class="member-right">
        <text class="member-hint">{{memberHint}}</text>
        <t-icon name="chevron-right" size="30rpx" />
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">功能入口</view>
    <t-grid column="4" border="{{false}}" hover="{{true}}">
      <t-grid-item text="去占卜" icon="gesture-pray-1" bind:click="goFortune" />
      <t-grid-item text="历史记录" icon="history" bind:click="goHistory" />
      <t-grid-item text="关于我们" icon="book-open" bind:click="goAbout" />
      <t-grid-item text="返回首页" icon="home" bind:click="goHome" />
    </t-grid>
  </view>
  <view class="tabbar-placeholder" />
</view>
