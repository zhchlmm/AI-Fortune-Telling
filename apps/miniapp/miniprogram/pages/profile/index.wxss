.container {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero {
  padding: 28rpx;
}

.member-level {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f8f9ff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.member-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.member-name {
  font-size: 27rpx;
  color: #111827;
  font-weight: 600;
}

.member-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.member-hint {
  font-size: 24rpx;
  color: #6b7280;
}
