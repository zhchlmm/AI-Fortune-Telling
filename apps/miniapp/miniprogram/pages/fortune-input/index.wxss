.container {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-card {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: var(--td-bg-color-container, #ffffff);
  border: 1rpx solid var(--td-component-border, #e7e7e7);
}

.result-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--td-text-color-primary, #1f2329);
  white-space: pre-wrap;
  word-break: break-word;
}

.result-error {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--td-error-color, #e34d59);
}
