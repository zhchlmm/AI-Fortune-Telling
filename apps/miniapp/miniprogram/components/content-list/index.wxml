<view class="content-list-wrap">
  <scroll-view scroll-x class="category-scroll" show-scrollbar="false">
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-chip {{activeCategoryId === item.id ? 'chip-active' : ''}}"
        data-category-id="{{item.id}}"
        bindtap="onCategoryChange"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <t-loading text="加载中" />
  </view>

  <view wx:elif="{{contents.length === 0}}">
    <t-empty description="{{emptyText}}" />
  </view>

  <view wx:else>
    <content-card
      wx:for="{{contents}}"
      wx:key="id"
      item="{{item}}"
      bind:open="onOpenDetail"
    />

    <view wx:if="{{loadingMore}}" class="loading-wrap">
      <t-loading text="加载更多中" />
    </view>

    <view wx:elif="{{!hasMore && contents.length > 0}}" class="loading-wrap muted">
      没有更多内容了
    </view>
  </view>
</view>
