<view class="tabbar-wrap">
  <view class="tabbar-main">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{selected === index ? 'tab-item-active' : ''}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <t-icon
        name="{{item.icon}}"
        size="44rpx"
        color="{{selected === index ? selectedColor : color}}"
      />
      <view class="tab-text" style="color: {{selected === index ? selectedColor : color}}">
        {{item.text}}
      </view>
    </view>
  </view>
  <view class="tabbar-safe" />
</view>
