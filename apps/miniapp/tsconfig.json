{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "strict": true,
    "noImplicitAny": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["miniprogram-api-typings"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@env/*": ["miniprogram/env/*"],
      "@services/*": ["miniprogram/services/*"]
    }
  },
  "include": ["./**/*.ts"]
}
